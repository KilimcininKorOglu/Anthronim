# Anthronim — Ortam Değişkenleri Şablonu
#
# Bu dosyayı `.env` olarak kopyalayın ve kendi değerlerinizle doldurun:
#     cp .env.example .env
#
# `.env` dosyası `.gitignore` içindedir ve Git'e dahil edilmez.
# İzinleri daraltmanız önerilir: `chmod 600 .env`

# --- Opsiyonel ---

# NVIDIA NIM API anahtarı (yedek).
# Yönetim panelinden anahtar eklendiyse gerekli değildir.
# NVIDIA_API_KEY=nvapi-...

# Proxy'ye erişimi kısıtlayan erişim anahtarı.
# Ayarlandığında istemcilerin `x-api-key` veya `Authorization: Bearer` başlığıyla
# aynı değeri göndermesi gerekir. Yerel geliştirmede boş bırakılabilir.
# AUTH_TOKEN=degistir-beni

# HTTP sunucusunun dinleyeceği port. Varsayılan: 8787
PORT=8787

# HTTP sunucusunun bağlanacağı arayüz. Varsayılan: 0.0.0.0
# Yalnızca yerel erişim için 127.0.0.1 kullanın.
HOST=0.0.0.0

# Model listesi önbellek süresi (milisaniye). Varsayılan: 3600000 (1 saat)
# MODEL_CACHE_TTL=3600000

# Reverse proxy arkasında çalışıyorsa `true` olarak ayarlayın.
# X-Forwarded-For başlığına yalnızca bu açıkken güvenilir.
# TRUST_PROXY=false

# İstek loglarının saklanma süresi (gün). Varsayılan: 30
# LOG_RETENTION_DAYS=30

# --- Yönetim Paneli (Opsiyonel) ---

# Her iki değişken de ayarlandığında /admin yolu aktif olur.
# HTTP Basic Auth kullanılır; TLS için reverse proxy önerilir.
ADMIN_USER=admin
ADMIN_PASS=degistir-beni
