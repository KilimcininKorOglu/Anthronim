{
  "name": "anthronim",
  "version": "1.4.0",
  "description": "Anthronim — Anthropic Messages API formatını NVIDIA NIM'e çeviren Node.js proxy",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:dev": "docker compose --profile dev up dev",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
